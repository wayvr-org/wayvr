<layout>

  <!--
  ids:
    "button"
    "image_preview"
    "label_title"
    "label_desc"
  -->
  <template name="Cell">
    <Button
      id="button"
      padding="8"
      round="8"
      flex_direction="column"
      gap="4"
      width="256"
      align_items="center"
      align_self="start">
      <image id="image_preview" width="100%" height="128" round="6"/>
      <label id="label_title" wrap="1" weight="bold"/>
      <label id="label_author" wrap="1"/>
    </Button>
  </template>
</layout>
